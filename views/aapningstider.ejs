<%- include('includes/_head') %>
<%- include('includes/_header') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-eyebrow">Informasjon</div>
    <h1 class="page-hero-title">Åpningstider & kontakt</h1>
    <p class="page-hero-desc">Vi holder til i Kongens gate 12 i Trondheim sentrum. Bestilling anbefales.</p>
  </div>
</section>

<main>
  <section class="inner-section">
    <div class="container">
      <div class="hours-cols">

        <div>
          <h2 class="home-section-title" style="margin-bottom:1.5rem;">Åpningstider</h2>
          <table class="hours-table">
            <tr><td>Mandag</td><td>09:00 – 18:00</td></tr>
            <tr><td>Tirsdag</td><td>09:00 – 18:00</td></tr>
            <tr><td>Onsdag</td><td>09:00 – 18:00</td></tr>
            <tr><td>Torsdag</td><td>09:00 – 19:00</td></tr>
            <tr><td>Fredag</td><td>09:00 – 18:00</td></tr>
            <tr><td>Lørdag</td><td>09:00 – 15:00</td></tr>
            <tr><td>Søndag</td><td class="hours-closed">Stengt</td></tr>
          </table>
          <div class="info-box" style="margin-top:1.5rem;">
            <strong>Bestilling anbefales.</strong> Vi tar imot drop-in når vi har ledig kapasitet — ring oss gjerne på forhånd.
          </div>
        </div>

        <div>
          <h2 class="home-section-title" style="margin-bottom:1.5rem;">Finn oss</h2>
          <ul class="contact-list">
            <li class="contact-item">
              <span class="contact-label">Adresse</span>
              <span class="contact-value">Kongens gate 12, 7013 Trondheim</span>
            </li>
            <li class="contact-item">
              <span class="contact-label">Telefon</span>
              <a class="contact-value contact-link" href="tel:73552210">73 55 22 10</a>
            </li>
            <li class="contact-item">
              <span class="contact-label">E-post</span>
              <a class="contact-value contact-link" href="mailto:post@solskinnfrisor.no">post@solskinnfrisor.no</a>
            </li>
            <li class="contact-item">
              <span class="contact-label">Instagram</span>
              <a class="contact-value contact-link" href="#">@solskinnfrisor</a>
            </li>
            <li class="contact-item">
              <span class="contact-label">Org.nummer</span>
              <span class="contact-value">924 837 651</span>
            </li>
          </ul>

          <div class="map-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            <span>Kongens gate 12, Trondheim sentrum</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="inner-section inner-section--alt">
    <div class="container">
      <h2 class="home-section-title" style="margin-bottom:.75rem;">Parkering & offentlig transport</h2>
      <p style="color:var(--sand-500);margin-bottom:1.5rem;line-height:1.8;">Vi ligger sentralt i Trondheim og er enkelt tilgjengelig med offentlig transport.</p>
      <div class="transport-grid">
        <div class="transport-card">
          <div class="transport-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <div class="transport-title">Buss</div>
          <div class="transport-desc">Holdeplass Kongens gate (linje 3, 5 og 10) — 1 min gange</div>
        </div>
        <div class="transport-card">
          <div class="transport-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="5" r="1.5" fill="currentColor" stroke="none"/><path d="M9 19l1.5-5L9 11l-2-2m6 10l-1.5-5 1.5-3 2-2M9 11h6"/></svg>
          </div>
          <div class="transport-title">Til fots</div>
          <div class="transport-desc">5 minutters gange fra Trondheim Sentralstasjon</div>
        </div>
        <div class="transport-card">
          <div class="transport-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><rect x="2" y="2" width="20" height="20" rx="3"/><text x="12" y="15.5" text-anchor="middle" font-size="9" font-weight="700" fill="currentColor" stroke="none" font-family="system-ui">P</text></svg>
          </div>
          <div class="transport-title">Parkering</div>
          <div class="transport-desc">P-hus Sirkus Shopping 200 m unna, gratis de første 30 min</div>
        </div>
      </div>
    </div>
  </section>
</main>

<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <h2 class="cta-band-title">Klar for en ny frisyre?</h2>
        <p class="cta-band-desc">Book en time i dag — raskt og enkelt på nett.</p>
      </div>
      <a href="/booking" class="btn btn-lg">Book time →</a>
    </div>
  </div>
</section>

<%- include('includes/_foot') %>
