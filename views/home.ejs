<%- include('includes/_head') %>
<%- include('includes/_header') %>

<section class="hero">
  <div class="container">
    <div class="hero-center">
      <div class="hero-logo-wrap">
        <img src="/images/logo.svg" alt="Solskinn Frisør" class="hero-logo-img">
      </div>
      <div class="hero-tag">Din lokale frisør i Trondheim</div>
      <h1 class="hero-title">Din beste <em>hårdag</em> starter her</h1>
      <p class="hero-desc">Erfarne frisører, hjertelig service og gode priser siden 2018. Vi holder til i hjertet av Trondheim sentrum.</p>
      <div class="hero-cta">
        <a href="/booking" class="btn btn-primary btn-lg">Book time →</a>
        <a href="/tjenester" class="btn btn-ghost btn-lg">Se tjenester</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hero-badge">
        <div class="hero-badge-val">4</div>
        <div class="hero-badge-lbl">Frisører</div>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-val">100+</div>
        <div class="hero-badge-lbl">Kunder/uke</div>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-val">4.9 ★</div>
        <div class="hero-badge-lbl">Google-vurdering</div>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-val">2018</div>
        <div class="hero-badge-lbl">Etablert</div>
      </div>
    </div>
  </div>
</section>

<main>
  <section class="home-section">
    <div class="container">
      <div class="home-section-header">
        <h2 class="home-section-title">Populære tjenester</h2>
        <a href="/tjenester" class="section-more">Se alle tjenester →</a>
      </div>
      <div class="services-grid">
        <% services.slice(0, 4).forEach(s => { %>
        <a href="/booking" class="service-tile">
          <div class="service-tile-name"><%= s.name %></div>
          <div class="service-tile-meta"><%= s.duration_minutes %> min<% if (s.description) { %> · <%= s.description %><% } %></div>
          <div class="service-tile-price">fra <%= s.price %> kr</div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-section-header">
        <h2 class="home-section-title">Våre frisører</h2>
        <a href="/tjenester#team" class="section-more">Møt teamet →</a>
      </div>
      <div class="workers-grid">
        <% workers.forEach(w => { %>
        <div class="worker-card">
          <div class="emp-avatar <%= w.avatar_color %>"><%= w.initials %></div>
          <div class="emp-name"><%= w.name %></div>
          <div class="emp-role"><%= w.role %></div>
          <div class="emp-days"><%= w.daysLabel %></div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="home-section home-section--alt">
    <div class="container">
      <div class="about-cols">
        <div>
          <div class="page-hero-eyebrow">Om oss</div>
          <h2 class="home-section-title" style="margin-bottom:1rem;">En salong med hjertet på rette sted</h2>
          <p style="color:var(--sand-500);line-height:1.8;margin-bottom:1rem;">
            Solskinn Frisør åpnet dørene i 2018 med én enkelt ambisjon: å gi Trondheims innbyggere
            en frisøropplevelse utenom det vanlige. Vi kombinerer solid fagkunnskap med en varm og
            uformell atmosfære der alle føler seg velkomne.
          </p>
          <p style="color:var(--sand-500);line-height:1.8;margin-bottom:1.75rem;">
            Teamet vårt består av fire erfarne frisører med spisskompetanse innen alt fra klassiske
            klipp til moderne fargeteknikker. Vi bruker kun miljøvennlige produkter fra <strong>Wella</strong>
            og <strong>Redken</strong>.
          </p>
          <a href="/aapningstider" class="btn btn-ghost">Finn oss her →</a>
        </div>
        <div class="about-info-cards">
          <div class="about-info-card">
            <div class="about-info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            </div>
            <div>
              <div class="about-info-label">Adresse</div>
              <div class="about-info-val">Kongens gate 12<br>7013 Trondheim</div>
            </div>
          </div>
          <div class="about-info-card">
            <div class="about-info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <div class="about-info-label">Telefon</div>
              <div class="about-info-val"><a href="tel:73552210">73 55 22 10</a></div>
            </div>
          </div>
          <div class="about-info-card">
            <div class="about-info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="about-info-label">E-post</div>
              <div class="about-info-val"><a href="mailto:post@solskinnfrisor.no">post@solskinnfrisor.no</a></div>
            </div>
          </div>
          <div class="about-info-card">
            <div class="about-info-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
            </div>
            <div>
              <div class="about-info-label">Åpningstider</div>
              <div class="about-info-val">Man–fre 09–18<br>Lør 09–15</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <h2 class="cta-band-title">Klar for en ny frisyre?</h2>
        <p class="cta-band-desc">Book en time i dag — raskt og enkelt på nett. Eller ring oss på <strong>73 55 22 10</strong>.</p>
      </div>
      <a href="/booking" class="btn btn-lg">Book time →</a>
    </div>
  </div>
</section>

<%- include('includes/_foot') %>
