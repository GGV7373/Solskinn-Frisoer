<%- include('includes/_head') %>
<%- include('includes/_header') %>

<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div>
        <div class="hero-tag">Din lokale frisør i Trøndelag</div>
        <h1 class="hero-title">Din beste<br><em>hårdag</em> starter her</h1>
        <p class="hero-desc">Erfarne frisører, hjertelig service og gode priser siden 2018.</p>
        <div class="hero-cta">
          <a href="/booking" class="btn btn-primary btn-lg">Book time →</a>
          <a href="#tjenester" class="btn btn-ghost btn-lg">Se tjenester</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-badge-wrap">
          <div class="hero-badge"><div class="hero-badge-val">4</div><div class="hero-badge-lbl">Frisører</div></div>
          <div class="hero-badge"><div class="hero-badge-val">100+</div><div class="hero-badge-lbl">Kunder/uke</div></div>
          <div class="hero-badge"><div class="hero-badge-val">4.9</div><div class="hero-badge-lbl">Stjerner</div></div>
          <div class="hero-badge"><div class="hero-badge-val">2018</div><div class="hero-badge-lbl">Etablert</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<main>
  <section class="home-section" id="tjenester">
    <div class="container">
      <div class="home-section-header">
        <h2 class="home-section-title">Tjenester</h2>
        <a href="/booking" class="btn btn-primary">Book time →</a>
      </div>
      <div class="services-grid">
        <% services.forEach(s => { %>
        <a href="/booking" class="service-tile">
          <div class="service-tile-name"><%= s.name %></div>
          <div class="service-tile-meta"><%= s.duration_minutes %> min<% if (s.description) { %> · <%= s.description %><% } %></div>
          <div class="service-tile-price">fra <%= s.price %> kr</div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-section-header">
        <h2 class="home-section-title">Våre frisører</h2>
      </div>
      <div class="workers-grid">
        <% workers.forEach(w => { %>
        <div class="worker-card">
          <div class="emp-avatar <%= w.avatar_color %>"><%= w.initials %></div>
          <div class="emp-name"><%= w.name %></div>
          <div class="emp-role"><%= w.role %></div>
          <div class="emp-days"><%= w.daysLabel %></div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="home-section" id="aapningstider">
    <div class="container">
      <h2 class="home-section-title" style="margin-bottom:1.5rem;">Åpningstider</h2>
      <div class="hours-cols">
        <table class="hours-table">
          <tr><td>Mandag – fredag</td><td>09:00 – 18:00</td></tr>
          <tr><td>Lørdag</td><td>09:00 – 15:00</td></tr>
          <tr><td>Søndag</td><td class="hours-closed">Stengt</td></tr>
        </table>
        <div class="info-box">
          <strong>Bestilling anbefales.</strong> Vi tar imot drop-in når vi har ledig kapasitet.
          Ring oss på <strong>37 02 11 xx</strong> for spørsmål.
        </div>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="container">
    <strong>Solskinn Frisør</strong> · Trøndelag · Tlf: 37 02 11 xx
  </div>
</footer>

<%- include('includes/_foot') %>
