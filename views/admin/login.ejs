<!DOCTYPE html>
<html lang="nb">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Logg inn · Solskinn Frisør</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="login-body">
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-logo">
        <img src="/images/logo.svg" alt="Solskinn Frisør" class="login-logo-img">
      </div>
      <h1 class="login-title">Admin-innlogging</h1>
      <p class="login-sub">Solskinn Frisør · Internt system</p>

      <% if (error) { %>
      <div class="admin-alert admin-alert--error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="login-form">
        <div class="admin-field">
          <label class="admin-label" for="password">Passord</label>
          <input class="admin-input" type="password" id="password" name="password" placeholder="Skriv inn passord" autofocus required>
        </div>
        <button class="admin-btn admin-btn--primary admin-btn--full" type="submit">Logg inn →</button>
      </form>

      <a href="/" class="login-back">← Tilbake til nettstedet</a>
    </div>
  </div>
</body>
</html>
